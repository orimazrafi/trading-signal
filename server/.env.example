DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_signal
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=1h
CLIENT_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
AUTH_ALLOW_MOCK=false
TWELVE_DATA_API_KEY=

# Market news ingest (worker polls Twelve Data and publishes to RabbitMQ)
NEWS_INGEST_ENABLED=true
NEWS_INGEST_INTERVAL_MS=300000
NEWS_INGEST_BATCH_SIZE=5
NEWS_INGEST_SYMBOLS=AAPL,MSFT,TSLA,NVDA,GOOGL

# Dashboard recommendations (worker scores symbols and caches in Redis)
RECOMMENDATIONS_ENABLED=true
RECOMMENDATIONS_INTERVAL_MS=300000
RECOMMENDATIONS_MAX_ITEMS=20
RECOMMENDATION_SYMBOLS=AAPL,MSFT,TSLA,NVDA,GOOGL,AMZN,META,JPM,XOM

# Stock history chart cache (daily bars from Twelve Data time_series)
STOCK_HISTORY_CACHE_TTL_SECONDS=3600

# Copy this file to server/.env and fill in secrets locally.
# server/.env is gitignored — never commit GOOGLE_CLIENT_SECRET or JWT_SECRET.