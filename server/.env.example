DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_signal
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1h
CLIENT_URL=http://localhost:5173
GOOGLE_CLIENT_ID=123456789012-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-example_dummy_secret_replace_me
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
AUTH_ALLOW_MOCK=false
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Market news ingest (worker polls Twelve Data and publishes to RabbitMQ)
NEWS_INGEST_ENABLED=true
NEWS_INGEST_INTERVAL_MS=300000
NEWS_INGEST_BATCH_SIZE=5
NEWS_INGEST_SYMBOLS=AAPL,MSFT,TSLA,NVDA,GOOGL

# Dashboard recommendations (worker scores symbols and caches in Redis)
RECOMMENDATIONS_ENABLED=true
RECOMMENDATIONS_INTERVAL_MS=300000
RECOMMENDATIONS_MAX_ITEMS=20
RECOMMENDATION_SYMBOLS=AAPL,MSFT,TSLA,NVDA,GOOGL,AMZN,META,JPM,XOM

# Stock history chart cache (daily bars from Twelve Data time_series)
STOCK_HISTORY_CACHE_TTL_SECONDS=3600

# Price alert emails (Resend — https://resend.com). Alerts are sent TO your sign-in email.
# For testing without a custom domain, use: EMAIL_FROM=onboarding@resend.dev
# With an unverified domain, Resend only delivers to the account owner email.
RESEND_API_KEY=re_example_dummy_key_replace_me
EMAIL_FROM=onboarding@resend.dev

# Copy this file to server/.env and replace dummy values with your real secrets.
# server/.env is gitignored — never commit real API keys or passwords.
