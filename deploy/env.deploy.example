# Copy to repo root on the VM as .env.deploy (never commit real values).
# Example: ghcr.io/my-github-user/trading-signal

GHCR_IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_USER/trading-signal
IMAGE_TAG=latest

# Strong random password for Postgres (also used in DATABASE_URL inside compose).
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Public URL — use a free subdomain (e.g. your-app.duckdns.org) pointing to the VM public IP.
SITE_DOMAIN=your-app.duckdns.org
CLIENT_URL=https://your-app.duckdns.org
GOOGLE_CALLBACK_URL=https://your-app.duckdns.org/api/v1/auth/google/callback
