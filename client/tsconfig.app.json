{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@trading-signal/contracts/recommendation": ["../packages/contracts/src/recommendation.ts"],
      "@trading-signal/contracts/alert": ["../packages/contracts/src/alert.ts"],
      "@trading-signal/contracts/auth": ["../packages/contracts/src/auth.ts"],
      "@trading-signal/contracts/parseAlertNotification": [
        "../packages/contracts/src/alert.ts"
      ],
      "@trading-signal/contracts/stock": ["../packages/contracts/src/stock.ts"],
      "@trading-signal/contracts/signal": ["../packages/contracts/src/signal.ts"],
      "@trading-signal/contracts/news": ["../packages/contracts/src/news.ts"],
      "@trading-signal/contracts/watchlist": ["../packages/contracts/src/watchlist.ts"],
      "@trading-signal/contracts/zodApi": ["../packages/contracts/src/lib/zodApi.ts"],
      "@trading-signal/contracts/httpStatus": ["../packages/contracts/src/httpStatus.ts"],
      "@trading-signal/contracts/apiPath": ["../packages/contracts/src/apiPath.ts"],
      "@trading-signal/contracts/pagination": ["../packages/contracts/src/pagination.ts"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"]
}
