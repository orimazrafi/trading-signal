{
  "name": "trading-signal",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "npm-run-all": "^4.1.5"
  },
  "overrides": {
    "zod": "3.25.76"
  },
  "scripts": {
    "build:contracts": "npm run build -w @trading-signal/contracts",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "build": "npm run build:contracts && npm run build:server && npm run build:client",
    "lint": "npm-run-all --parallel lint:client lint:server",
    "lint:client": "npm run lint -w client",
    "lint:server": "npm run lint -w server",
    "test:contracts": "npm run test -w @trading-signal/contracts",
    "test:server": "npm run test -w server",
    "test:client": "npm run test -w client",
    "test:integration": "npm run test:integration -w server",
    "test:go": "go test -C alerts-runner ./...",
    "test:unit": "npm-run-all --parallel test:contracts test:server test:client",
    "test": "npm run test:unit && npm run test:integration",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "postinstall": "npm run build:contracts && npm run db:generate -w server"
  }
}
